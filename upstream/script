#!/bin/sh

# BioProject: PRJNA1161137

conda activate rnaseq

# 01-Download raw fastq from SRA database

prefetch SRR30668268
prefetch SRR30668269
prefetch SRR30668270
prefetch SRR30668271
prefetch SRR30668272
prefetch SRR30668273

# 02-Estract, split and compress fastq files

fasterq-dump SRR30668268 --split-files --skip-technical --threads 4
fasterq-dump SRR30668269 --split-files --skip-technical --threads 4
fasterq-dump SRR30668270 --split-files --skip-technical --threads 4
fasterq-dump SRR30668271 --split-files --skip-technical --threads 4
fasterq-dump SRR30668272 --split-files --skip-technical --threads 4
fasterq-dump SRR30668273 --split-files --skip-technical --threads 4

pigz -p 4 ./fastq/SRR30668268_*.fastq
pigz -p 4 ./fastq/SRR30668269_*.fastq
pigz -p 4 ./fastq/SRR30668270_*.fastq
pigz -p 4 ./fastq/SRR30668271_*.fastq
pigz -p 4 ./fastq/SRR30668272_*.fastq
pigz -p 4 ./fastq/SRR30668273_*.fastq

# 03-Perform FastQC and MultiQC on compressed FASTQ files

fastqc -t 4 -o ./report/fastqc/first ./fastq/SRR30668268_*.fastq.gz
fastqc -t 4 -o ./report/fastqc/first ./fastq/SRR30668269_*.fastq.gz
fastqc -t 4 -o ./report/fastqc/first ./fastq/SRR30668270_*.fastq.gz
fastqc -t 4 -o ./report/fastqc/first ./fastq/SRR30668271_*.fastq.gz
fastqc -t 4 -o ./report/fastqc/first ./fastq/SRR30668272_*.fastq.gz
fastqc -t 4 -o ./report/fastqc/first ./fastq/SRR30668273_*.fastq.gz

multiqc ./report/fastqc/first -o ./report/multiqc/first

# 04-Perform Trimmomatic for remove adapter contents
#SRR30668268

trimmomatic PE \
-threads 4 \
./fastq/SRR30668268_1.fastq.gz \
./fastq/SRR30668268_2.fastq.gz \
./report/trimmomatic/clean/SRR30668268_1_trim.fastq.gz \
./report/trimmomatic/unpaired/SRR30668268_1_unpa.fastq.gz \
./report/trimmomatic/clean/SRR30668268_2_trim.fastq.gz \
./report/trimmomatic/unpaired/SRR30668268_2_unpa.fastq.gz \
ILLUMINACLIP:$HOME/miniconda3/envs/rnaseq/share/trimmomatic/adapters/TruSeq3-PE.fa:2:30:10 \
SLIDINGWINDOW:4:20 \
LEADING:3 \
TRAILING:3 \
MINLEN:50

#SRR30668269

trimmomatic PE \
-threads 4 \
./fastq/SRR30668269_1.fastq.gz \
./fastq/SRR30668269_2.fastq.gz \
./report/trimmomatic/clean/SRR30668269_1_trim.fastq.gz \
./report/trimmomatic/unpaired/SRR30668269_1_unpa.fastq.gz \
./report/trimmomatic/clean/SRR30668269_2_trim.fastq.gz \
./report/trimmomatic/unpaired/SRR30668269_2_unpa.fastq.gz \
ILLUMINACLIP:$HOME/miniconda3/envs/rnaseq/share/trimmomatic/adapters/TruSeq3-PE.fa:2:30:10 \
SLIDINGWINDOW:4:20 \
LEADING:3 \
TRAILING:3 \
MINLEN:50

#SRR30668270

trimmomatic PE \
