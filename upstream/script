multiqc ./report/fastqc/firtrimst -o ./report/multiqc/trim

# 06-Aligment using HISAT2
#SRR30668268

hisat2 -p 4 \
-x /Users/davidemaccarrone/references/index_hisat2/index_hisat2 \
