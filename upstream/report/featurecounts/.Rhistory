count <- read.table("counts.txt", sep = "\t", header = T, skip = 1)
count <- count[, -c(2:6)]
rownames(count) <- count$Geneid
count <- count[,-1]
sample <- c("CT3", "CT2", "CT1", "CC3", "CC2", "CC1")
colnames(count) <- sample
dim(count)
meta <- tibble(
Geneid = rownames(count)
)
meta$symbol <- mapIds(
org.Hs.eg.db,
keys = meta$Geneid,
keytype = "ENSEMBL",
column = "SYMBOL",
multiVals = "first"
)
meta$entrez <- mapIds(
org.Hs.eg.db,
keys = meta$Geneid,
keytype = "ENSEMBL",
column = "ENTREZID",
multiVals = "first"
)
setwd("~/edgeR/upstream/report/featurecounts")
library(tidyverse)
library(edgeR)
library(AnnotationDbi)
library(org.Hs.eg.db)
library(pheatmap)
library(clusterProfiler)
library(ReactomePA)
count <- read.table("counts.txt", sep = "\t", header = T, skip = 1)
count <- count[, -c(2:6)]
rownames(count) <- count$Geneid
count <- count[,-1]
sample <- c("CT3", "CT2", "CT1", "CC3", "CC2", "CC1")
colnames(count) <- sample
dim(count)
meta <- tibble(
Geneid = rownames(count)
)
meta$symbol <- mapIds(
org.Hs.eg.db,
keys = meta$Geneid,
keytype = "ENSEMBL",
column = "SYMBOL",
multiVals = "first"
)
meta$entrez <- mapIds(
org.Hs.eg.db,
keys = meta$Geneid,
keytype = "ENSEMBL",
column = "ENTREZID",
multiVals = "first"
)
meta <- as.data.frame(meta)
# 02-Create a DGEList
group<- factor(c(rep("NoTreatment",3), rep("Treatment",3)))
dgelist <- DGEList(counts = count, group = group, genes = meta)
str(dgelist)
# 03-Filtering using filterByExp() function
keep <- filterByExpr(dgelist)
dgelist <- dgelist[keep, , keep.lib.sizes = FALSE]
barplot(dgelist$samples$lib.size*1e-6, names = 1:6, ylab = "Library size before normalization (millions)")
plotMDS(dgelist, col = as.numeric(group))
boxplot(cpm(dgelist, log = TRUE, prior.count = 1),
las = 2,
main = "LogCPM before TMM normalization")
dgelist <- calcNormFactors(dgelist, method = "TMM")
boxplot(cpm(dgelist, log = TRUE, prior.count = 1),
las = 2,
main = "LogCPM after TMM normalization")
#MDS
pch <- c(16,17)
color_MDS <- c("darkgreen", "darkblue")
for (i in 1:6){
plotMD(dgelist, column = i,  main = colnames(dgelist)[i] )
abline(h = 0, col = "red", lty = 2, lwd = 2)
}
#PCA
logCPM <- cpm(dgelist, log = TRUE, prior.count = 1)
pca <- prcomp(t(logCPM), scale. = TRUE)
pca_var <- pca$sdev^2
pca_var_percent <- round(100 * pca_var / sum(pca_var), 1)
metadata <- data.frame(
Sample = colnames(logCPM),
Group = factor(c(rep("NoTreatment",3), rep("Treatment",3)))
)
pca_df <- data.frame(pca$x[,1:2], metadata)
ggplot(pca_df, aes(x=PC1, y=PC2, color=Group, label=Sample)) +
geom_point(size=2.5) +
geom_text(vjust=-0.5, size=3) +
xlab(paste0("PC1 (", pca_var_percent[1], "%)")) +
ylab(paste0("PC2 (", pca_var_percent[2], "%)")) +
theme_bw() +
scale_color_manual(values=c("darkgreen","darkblue")) +
ggtitle("PCA plot of normalized logCPM")
distance <- dist(t(cpm(dgelist, log = TRUE, prior.count = 1)))
pheatmap(as.matrix(distance))
dgelist <- estimateCommonDisp(dgelist)
dgelist <- estimateTagwiseDisp(dgelist)
cat("Common BCV:", sqrt(dgelist$common.dispersion), "\n")
plotBCV(dgelist)
plotMeanVar(dgelist)
exact_test <- exactTest(dgelist, pair = c("NoTreatment", "Treatment"))
res <- topTags(exact_test, n = Inf)
deg <- res$table
deg_fil <- deg[deg$FDR < 0.05 & abs(deg$logFC) > 1, ]
deg_up <- deg_fil[deg_fil$logFC > 0, ]
deg_down <- deg_fil[deg_fil$logFC < 0, ]
cat(
"------Differentially expressed genes------", "\n",
"Total DEGs: ", length(deg_fil), "\n",
"DEGs up-regulated: ", length(deg_up), "\n",
"DEGs down-regulated: ", length(deg_down), "\n"
)
cat(
"------Differentially expressed genes------", "\n",
"Total DEGs: ", dim(deg_fil), "\n",
"DEGs up-regulated: ", length(deg_up), "\n",
"DEGs down-regulated: ", length(deg_down), "\n"
)
cat(
"------Differentially expressed genes------", "\n",
"Total DEGs: ", nrow(deg_fil), "\n",
"DEGs up-regulated: ", nrow(deg_up), "\n",
"DEGs down-regulated: ", nrow(deg_down), "\n"
)
cat(
"------Differentially expressed genes------", "\n",
"Total DEGs: ", nrow(deg_fil), "\n",
"DEGs up-regulated: ", nrow(deg_up), "\n",
"DEGs down-regulated: ", nrow(deg_down), "\n"
)
cat(
"------Differentially expressed genes------", "\n",
"\n",
"Total DEGs: ", nrow(deg_fil), "\n",
"DEGs up-regulated: ", nrow(deg_up), "\n",
"DEGs down-regulated: ", nrow(deg_down), "\n"
)
cat(
"------Differentially expressed genes------", "\n", "\n",
"Total DEGs: ", nrow(deg_fil), "\n",
"DEGs up-regulated: ", nrow(deg_up), "\n",
"DEGs down-regulated: ", nrow(deg_down), "\n"
)
deg_genes <- rownames(deg_fil)
count_deg <- dgelist$counts[deg_genes, ]
logCPM_deg <- cpm(DGEList(counts=count_deg), log=TRUE, prior.count=1)
logCPM_deg_scaled <- t(scale(t(logCPM_deg)))
annotation_col <- data.frame(
Group = factor(c(rep("NoTreatment",3), rep("Treatment",3)))
)
rownames(annotation_col) <- colnames(logCPM_deg_scaled)
pheatmap(
logCPM_deg_scaled,
annotation_col = annotation_col,
show_rownames = FALSE,      # nasconde i nomi dei geni, puoi cambiare a TRUE se vuoi
cluster_rows = TRUE,        # cluster dei geni
cluster_cols = TRUE,        # cluster dei campioni
scale = "none",              # ogni gene centrato e scalato
color = colorRampPalette(c("navy","white","firebrick3"))(50)
)
View(count_deg)
deg_genes <- rownames(deg_fil)
deg_genes
View(deg_genes)
View(deg_fil)
ggplot(deg_fil, aes(x=logFC, y=-log10(FDR))) +
geom_point(alpha=0.6) +
geom_vline(xintercept=c(-1,1), linetype="dashed") +
geom_hline(yintercept=-log10(0.05), linetype="dashed") +
theme_bw()
ggplot(deg_fil, aes(x=logFC, y=-log10(FDR))) +
geom_point(alpha=0.6) +
geom_vline(xintercept=c(-1,1), linetype="dashed") +
geom_hline(yintercept=-log10(0.05), linetype="dashed") +
theme_bw() +
labs(
title = "Volcano plot of DEGs",
x = "Log2 Fold Change",
y = "-Log10(FDR)",
color = "Regulation"
)
plotMD(exact_test)
abline(h = c(-1,1), col = "blue")
abline(h = c(-1,1), col = "blue", main = "MD plot of exact-test Data")
deg <- res$table
plotMD(exact_test)
abline(h = c(-1,1), col = "blue", main = "MD plot of exact-test Data")
plotMD(exact_test)
abline(h = c(-1,1), col = "blue", main = "MD plot of exact-test Data")
